{
  "manifest": {
    "id": "markdown",
    "name": "Markdown",
    "version": "0.1.0",
    "plugin": true,
    "namespace": "markdown",
    "description": {
      "default": "Render Markdown to Aglet's canonical UI IR.",
      "zh": "把 Markdown 渲染成 Aglet 的标准 UI IR。",
      "ja": "Markdown を Aglet の標準 UI IR にレンダリング。"
    },
    "keywords": ["markdown","render","ir","gfm"],
    "license": "MIT",
    "homepage": "https://github.com/aglet-dev/plugins",
    "actions": [
      {
        "name": "render",
        "params": [
          {
            "key": "text",
            "type": "string"
          }
        ],
        "result": [
          {
            "key": "nodes",
            "type": "array"
          }
        ],
        "permission": "markdown:render"
      }
    ],
    "backend": {
      "kind": "wasm",
      "path": "dist/markdown.wasm",
      "wasi_imports": [
        "wasi_snapshot_preview1.random_get",
        "wasi_snapshot_preview1.environ_get",
        "wasi_snapshot_preview1.environ_sizes_get",
        "wasi_snapshot_preview1.fd_write",
        "wasi_snapshot_preview1.proc_exit"
      ]
    }
  }
}
